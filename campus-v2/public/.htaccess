# Hostinger .htaccess - MetodologIA Campus v2
# Soporte para SPA (Single Page Application) en la carpeta donde se publique `dist/`

RewriteEngine On

# Re-declara una CSP compatible con Campus para evitar que la politica global
# del sitio bloquee las llamadas del frontend hacia Supabase.
<IfModule mod_headers.c>
    Header always unset Content-Security-Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://unpkg.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https: blob:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.metodologia.info https://*.supabase.co wss://*.supabase.co; object-src 'none'; media-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'self';"
</IfModule>

# Evitar bucles en index.html
RewriteRule ^index\.html$ - [L]

# Si el archivo o carpeta solicitada no existe, redirigir a index.html
# Esto permite que el router de JavaScript tome el control de la URL.
# La regla es relativa al directorio donde vive este `.htaccess`, por lo que
# funciona igual si despliegas en raiz o en una subcarpeta.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . index.html [L]

# Optimizaciones de Cache (Opcional pero recomendado para NFR-08)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>
